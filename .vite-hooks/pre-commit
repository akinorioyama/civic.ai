# Vite+ pre-commit hook: run staged checks, then gate large diffs behind a full parity build.
vp staged

if git diff --cached --quiet -- \
    "*.md" "*.html" \
    "_data/**" "src/**" \
    "assets/**" "audio/**" "fonts/**" "img/**" \
    "styles.css" "CNAME" ".nojekyll" "favicon.ico" "favicon.svg" \
    "astro.config.mjs" "package.json" "bun.lock" \
    "scripts/sync-public.mjs" "scripts/check-build-parity.mjs" \
    "tests/fixtures/eleventy-build-baseline.json"
then
    exit 0
fi

vp run build:parity
vp run check:parity
