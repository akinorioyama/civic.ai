{
    "name": "civic.ai",
    "type": "module",
    "packageManager": "bun@1.3.14",
    "engines": {
        "node": ">=22.12.0"
    },
    "devEngines": {
        "runtime": {
            "name": "node",
            "version": "22.23.1",
            "onFail": "download"
        },
        "packageManager": {
            "name": "bun",
            "version": "1.3.14",
            "onFail": "download"
        }
    },
    "scripts": {
        "prepare": "vp config",
        "sync:public": "bun scripts/sync-public.mjs",
        "minify-html": "bun scripts/minify-html.mjs",
        "lint": "vp fmt --check . && vp lint && bun pangu-format.mjs --check && bun scripts/check-tw-typography.mjs",
        "format": "vp fmt . && bun pangu-format.mjs",
        "build:parity": "vp run sync:public && vp exec astro build",
        "check-links": "BUILD_DIR=dist bun check-links.mjs",
        "check:hybrid": "BUILD_DIR=dist bun scripts/check-hybrid-design.mjs",
        "check:astro-output": "BUILD_DIR=dist bun scripts/check-astro-output.mjs",
        "check:parity": "BUILD_DIR=dist BASELINE_IN=tests/fixtures/eleventy-build-baseline.json bun scripts/check-build-parity.mjs",
        "check:search": "BUILD_DIR=dist bun scripts/check-search-output.mjs",
        "vectorize:sync-site": "bun scripts/vectorize-sync-site.mjs",
        "worker:typecheck": "cd worker && bun run typecheck",
        "worker:test": "cd worker && bun run test",
        "import-comics": "bun import-comics.mjs",
        "en": "bun scripts/review-set.mjs en",
        "tw": "bun scripts/review-set.mjs tw",
        "ci": "vp check && vp test && vp build && vp run check-links && vp run check:hybrid && vp run check:astro-output && vp run check:search && vp run check:parity && vp run worker:typecheck && vp run worker:test"
    },
    "dependencies": {
        "markdown-it-anchor": "^9.2.0",
        "markdown-it-footnote": "^4.0.0",
        "pangu": "^7.2.1",
        "remark": "^15.0.1",
        "remark-pangu": "^2.2.0",
        "remark-parse": "^11.0.0",
        "remark-stringify": "^11.0.0",
        "astro": "^7.0.6",
        "gray-matter": "^4.0.3",
        "markdown-it": "^14.1.0",
        "nunjucks": "^3.2.4"
    },
    "devDependencies": {
        "@vitest/coverage-v8": "4.1.10",
        "fuse.js": "^6.6.2",
        "html-minifier": "^4.0.0",
        "pagefind": "1.5.0-beta.1",
        "@types/markdown-it": "^14.1.2",
        "typescript": "^7.0.2",
        "@types/nunjucks": "^3.2.6",
        "vite": "npm:@voidzero-dev/vite-plus-core@0.2.4",
        "vite-plus": "0.2.4"
    },
    "overrides": {
        "vite": "npm:@voidzero-dev/vite-plus-core@0.2.4"
    }
}
