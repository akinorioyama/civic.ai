{
    "name": "civic.ai",
    "type": "module",
    "private": true,
    "devDependencies": {
        "@11ty/eleventy": "^3.1.6",
        "@types/bun": "latest",
        "html-minifier": "^4.0.0",
        "husky": "^9.1.7",
        "lint-staged": "^16.4.0",
        "prettier": "^3.8.4"
    },
    "peerDependencies": {
        "typescript": "^5.9.3"
    },
    "scripts": {
        "dev": "eleventy --serve",
        "build": "eleventy",
        "lint": "prettier --check . && bun run pangu-format.mjs --check",
        "format": "prettier --write . && bun run pangu-format.mjs",
        "prepare": "husky",
        "check-links": "bun run check-links.mjs",
        "import-comics": "node import-comics.mjs",
        "en": "node scripts/review-set.mjs en",
        "tw": "node scripts/review-set.mjs tw"
    },
    "lint-staged": {
        "**/*": "prettier --write --ignore-unknown",
        "**/*.md": "bun run pangu-format.mjs"
    },
    "dependencies": {
        "markdown-it-anchor": "^9.2.0",
        "markdown-it-footnote": "^4.0.0",
        "pangu": "^7.2.1",
        "remark": "^15.0.1",
        "remark-pangu": "^2.2.0",
        "remark-parse": "^11.0.0",
        "remark-stringify": "^11.0.0"
    }
}
