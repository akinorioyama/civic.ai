{
    "name": "civic.ai",
    "type": "module",
    "engines": {
        "node": ">=22.12.0"
    },
    "devEngines": {
        "packageManager": {
            "name": "bun",
            "version": "1.3.14",
            "onFail": "download"
        }
    },
    "scripts": {
        "dev": "bun run sync:public && bunx --bun astro dev --host 127.0.0.1",
        "build": "bun run sync:public && astro build && bun run minify-html && bunx pagefind --site dist",
        "build:parity": "bun run sync:public && astro build",
        "lint": "vp fmt --check . && vp lint && bun run pangu-format.mjs --check && bun scripts/check-tw-typography.mjs",
        "format": "vp fmt . && bun run pangu-format.mjs",
        "prepare": "vp config",
        "check": "tsc --noEmit",
        "test": "bun test",
        "sync:public": "bun run scripts/sync-public.mjs",
        "minify-html": "bun run scripts/minify-html.mjs",
        "check-links": "BUILD_DIR=dist bun run check-links.mjs",
        "check:hybrid": "BUILD_DIR=dist bun run scripts/check-hybrid-design.mjs",
        "check:astro-output": "BUILD_DIR=dist bun run scripts/check-astro-output.mjs",
        "check:parity": "BUILD_DIR=dist BASELINE_IN=tests/fixtures/eleventy-build-baseline.json bun run scripts/check-build-parity.mjs",
        "check:search": "BUILD_DIR=dist bun run scripts/check-search-output.mjs",
        "vectorize:sync-site": "bun scripts/vectorize-sync-site.mjs",
        "worker:typecheck": "cd worker && bun run typecheck",
        "worker:test": "cd worker && bun run test",
        "import-comics": "bun import-comics.mjs",
        "en": "bun scripts/review-set.mjs en",
        "tw": "bun scripts/review-set.mjs tw"
    },
    "dependencies": {
        "markdown-it-anchor": "^9.2.0",
        "markdown-it-footnote": "^4.0.0",
        "pangu": "^7.2.1",
        "remark": "^15.0.1",
        "remark-pangu": "^2.2.0",
        "remark-parse": "^11.0.0",
        "remark-stringify": "^11.0.0",
        "astro": "^7.0.6",
        "gray-matter": "^4.0.3",
        "markdown-it": "^14.1.0",
        "nunjucks": "^3.2.4"
    },
    "devDependencies": {
        "@types/bun": "latest",
        "fuse.js": "^6.6.2",
        "html-minifier": "^4.0.0",
        "pagefind": "1.5.0-beta.1",
        "@types/markdown-it": "^14.1.2",
        "typescript": "^7.0.2",
        "@types/nunjucks": "^3.2.6",
        "vite": "npm:@voidzero-dev/vite-plus-core@0.2.4",
        "vite-plus": "0.2.4"
    },
    "overrides": {
        "vite": "npm:@voidzero-dev/vite-plus-core@0.2.4"
    }
}
