---
import type { ActionLink, PageRecord } from "../lib/pages";
import { lang2, site } from "../lib/site";
import { normalizeSearchLang } from "../lib/search";
import ClientScripts from "../components/ClientScripts.astro";
import ComicsJaOverlay from "../components/ComicsJaOverlay.astro";
import InShort from "../components/InShort.astro";
import PageHead from "../components/PageHead.astro";
import PartnerColophon from "../components/PartnerColophon.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SearchOverlay from "../components/SearchOverlay.astro";

interface Props { page: PageRecord; }
const { page } = Astro.props;
const zh = lang2(page.data.lang) === "zh";
const isJaComics =
    page.data.lang === "ja" && page.data.page_class === "comics-page";
const pagefindIndexed =
    page.includeInSitemap === true &&
    page.data.search_exclude !== true &&
    normalizeSearchLang(page.data.lang) === "en";
const chapterOrder = site.chapters;
const key = page.url.replace(/^\/tw\//, "").replace(/^\//, "").replace(/\/$/, "");
const index = chapterOrder.indexOf(key);
function linkFor(slug: string, direction: "prev" | "next"): ActionLink {
    const prefix = zh ? "/tw" : "";
    const label = zh ? (direction === "prev" ? "上一章" : "下一章") : (direction === "prev" ? "Previous" : "Next");
    return { url: `${prefix}/${slug}/`, text: label };
}
const previousSlug = index > 0 ? chapterOrder[index - 1] : undefined;
const nextSlug = index >= 0 && index < chapterOrder.length - 1 ? chapterOrder[index + 1] : undefined;
const hasExplicitNav = Boolean(page.data.nav_prev || page.data.nav_next);
const prev = page.data.nav_prev || (!hasExplicitNav && previousSlug ? linkFor(previousSlug, "prev") : !hasExplicitNav ? { url: zh ? "/tw/" : "/", text: zh ? "首頁" : "Home" } : undefined);
const next = page.data.nav_next || (!hasExplicitNav && nextSlug ? linkFor(nextSlug, "next") : undefined);
const authors = page.data.author
    ? [{ "@type": "Person", name: page.data.author }]
    : [
          { "@type": "Person", name: "Audrey Tang", url: "https://audreyt.org", sameAs: ["https://en.wikipedia.org/wiki/Audrey_Tang", "https://www.wikidata.org/wiki/Q181916"] },
          { "@type": "Person", name: "Caroline Green", url: "https://www.oxford-aiethics.ox.ac.uk/caroline-emmer-de-albuquerque-green" },
      ];
const articleLd: Record<string, unknown> = {
    "@context": "https://schema.org",
    "@type": "Article",
    headline: page.data.title,
    description: page.data.meta_description || page.data.summary || page.data.description,
    url: `${site.url}${page.url}`,
    mainEntityOfPage: `${site.url}${page.url}`,
    inLanguage: zh ? "zh-Hant" : "en-GB",
    author: authors,
    publisher: { "@type": "Organization", name: "Oxford Institute for Ethics in AI", url: "https://www.oxford-aiethics.ox.ac.uk/", logo: { "@type": "ImageObject", url: `${site.url}/img/oxford-logo.svg` } },
    isPartOf: { "@type": "WebSite", name: "Civic AI", url: site.url },
};
if (page.data.date) articleLd.datePublished = page.data.date;
if (page.data.og_image || page.data.thumbnail) articleLd.image = `${site.url}${page.data.og_image || page.data.thumbnail}`;
---
<!doctype html>
<html lang={page.data.lang || "en"}>
  <head><PageHead page={page} ogType="article" preloadFont="/fonts/cormorant-normal-latin.woff2" /></head>
  <body class={page.data.page_class}>
    <a class="skip-link" href="#main">{zh ? "跳至內容" : "Skip to content"}</a>
    <SiteHeader page={page} />
    <SearchOverlay page={page} />
    <main
      id="main"
      {...(pagefindIndexed
        ? {
              "data-pagefind-body": true,
              "data-pagefind-filter": `lang:${normalizeSearchLang(page.data.lang)}`,
              "data-pagefind-meta": `section:${page.data.title || page.url}`,
          }
        : {})}
    ><InShort page={page} />{page.data.audio && <div class="audio-section"><audio controls preload="metadata" title="Narrated in Audrey's own AI voice"><source src={page.data.audio} type="audio/mpeg" /></audio></div>}<Fragment set:html={page.html} /></main>
    <section class="next-action"><div class="next-action-content">
      {prev && <a href={prev.url} class="next-action-button">{!hasExplicitNav && <span class="button-arrow">←</span>}<span class="button-text">{prev.text}</span></a>}
      {next && <a href={next.url} class="next-action-button"><span class="button-text">{next.text}</span>{!hasExplicitNav && <span class="button-arrow">→</span>}</a>}
    </div></section>
    <PartnerColophon lang={page.data.lang} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(articleLd)}></script>
    <ClientScripts page={page} />
    {isJaComics && <ComicsJaOverlay />}
  </body>
</html>
