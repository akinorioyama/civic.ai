---
import type { PageRecord } from "../lib/pages";
import { formatDateDisplay } from "../lib/site";
import HeaderTools from "./HeaderTools.astro";
import SiteLogos from "./SiteLogos.astro";
import SiteNav from "./SiteNav.astro";
import SiteWordmark from "./SiteWordmark.astro";

interface Props { page: PageRecord; headerTitle?: string; headerSubtitle?: string; headerDate?: string; }
const { page, headerTitle, headerSubtitle, headerDate } = Astro.props;
const isHome = page.url === "/" || page.url === "/tw/";
const displayTitle = headerTitle || page.data.header_title || page.data.title;
const displaySubtitle = headerSubtitle || page.data.subtitle;
---
<header class:list={["site-header", isHome ? "site-header--home" : "site-header--interior"]}>
  {isHome ? (
    <>
      <HeaderTools lang={page.data.lang} altLangUrl={page.data.alt_lang_url} />
      <SiteLogos lang={page.data.lang} />
      <h1><span style="white-space: nowrap">{displayTitle}</span>{displaySubtitle && <><span style="font-weight: 300">-</span><span style="white-space: nowrap">{displaySubtitle}</span></>}</h1>
      {page.data.description && <p>{page.data.description}</p>}
      {page.data.manifesto_link && <><br /><a href={page.data.manifesto_link} class="next-action-button"><span class="button-text">{page.data.manifesto_text}</span></a></>}
      <SiteNav lang={page.data.lang} />
    </>
  ) : (
    <>
      <div class="site-header__bar">
        <SiteWordmark lang={page.data.lang} />
        <HeaderTools lang={page.data.lang} altLangUrl={page.data.alt_lang_url} />
        <div class="site-header__nav"><SiteNav lang={page.data.lang} /></div>
      </div>
      <div class="site-header__frame-rule" aria-hidden="true"></div>
      <div class="site-header__title-block">
        <h1>{displayTitle}{displaySubtitle && <span>{displaySubtitle}</span>}</h1>
        {headerDate ? <p class="chapter-date">{headerDate}</p> : page.data.date ? <p class="chapter-date">{formatDateDisplay(page.data.date, page.data.lang)}</p> : null}
        {page.data.author && <p class="chapter-date">{page.data.author}</p>}
        {page.data.description && <p>{page.data.description}</p>}
      </div>
    </>
  )}
</header>