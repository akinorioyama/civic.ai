---
import { lang2, normalizeAltUrl } from "../lib/site";
interface Props {
    lang: string | undefined;
    altLangUrl?: string;
}
const { lang, altLangUrl } = Astro.props;
const zh = lang2(lang) === "zh";
const alt = normalizeAltUrl(altLangUrl);
---
<div class="site-header__tools">
  {alt && <a href={alt} class="lang-toggle">{zh ? "English" : "繁體中文"}</a>}
  <button class="theme-toggle" type="button" data-theme-toggle aria-label={zh ? "切換明暗主題" : "Toggle light and dark theme"}>
    <svg class="theme-toggle__icon theme-toggle__moon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
      <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
    </svg>
    <svg class="theme-toggle__icon theme-toggle__sun" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
      <circle cx="12" cy="12" r="4" />
      <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41" />
    </svg>
  </button>
</div>