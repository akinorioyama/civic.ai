---
import { lang2 } from "../lib/site";
import CivicBug from "./CivicBug.astro";
const zh = lang2(Astro.props.lang) === "zh";
const href = zh ? "/tw/" : "/";
---
<a href={href} class="site-wordmark" title={zh ? "仁工智慧首頁" : "Civic AI home"}>
  <CivicBug class="site-mark" />
  {zh ? (
    <>
      <span>仁工智慧</span>
      <span class="site-wordmark__secondary">civic.ai</span>
    </>
  ) : (
    <>
      <span>civic.ai</span>
      <span class="site-wordmark__secondary">仁工智慧</span>
    </>
  )}
</a>