<script is:inline>
    // @ts-nocheck
    (() => {
        const NS = "__jaComicsOverlay__";
        const html = document.documentElement;
        const MIN_SCALE = 0.3;
        const ITER = 12;

        const FS_OVERRIDES = {
            "5cqw": "3cqw",
        };

        const layers = () => [...document.querySelectorAll(".ja-ov-layer")];
        if (!layers().length) return;

        const isJa = () =>
            /^ja(-|$)/i.test((html.getAttribute("lang") || "").trim());

        const overflowing = (e) =>
            e.scrollHeight > e.clientHeight + 1 ||
            e.scrollWidth > e.clientWidth + 1;
        const parseFs = (v) => {
            const m = String(v)
                .trim()
                .match(/^([\d.]+)([a-z%]*)$/i);
            return m ? { n: parseFloat(m[1]), unit: m[2] || "px" } : null;
        };
        const norm = (v) => String(v).trim().toLowerCase();
        const markOrig = (box) => {
            if (!box.hasAttribute("data-jafit"))
                box.setAttribute(
                    "data-jafit",
                    box.style.getPropertyValue("--fs")
                );
        };
        const setFs = (box, val) => {
            markOrig(box);
            box.style.setProperty("--fs", val, "important");
        };
        const restoreFs = () =>
            document.querySelectorAll("[data-jafit]").forEach((e) => {
                const o = e.getAttribute("data-jafit");
                if (o) e.style.setProperty("--fs", o);
                else e.style.removeProperty("--fs");
                e.removeAttribute("data-jafit");
            });
        const applyOverride = (box) => {
            const key = norm(box.style.getPropertyValue("--fs"));
            if (!(key in FS_OVERRIDES)) return false;
            const spec = FS_OVERRIDES[key];
            if (typeof spec === "number") {
                const b = parseFs(box.style.getPropertyValue("--fs"));
                if (b) setFs(box, +(b.n * spec).toFixed(4) + b.unit);
            } else setFs(box, spec);
            return true;
        };
        const fitBox = (box) => {
            const base = parseFs(
                box.style.getPropertyValue("--fs") ||
                    getComputedStyle(box).getPropertyValue("--fs")
            );
            if (!base || !base.n) return;
            if (!overflowing(box)) return;
            const set = (k) => setFs(box, +(base.n * k).toFixed(4) + base.unit);
            set(MIN_SCALE);
            if (overflowing(box)) return;
            let lo = MIN_SCALE,
                hi = 1;
            for (let i = 0; i < ITER; i++) {
                const mid = (lo + hi) / 2;
                set(mid);
                if (overflowing(box)) hi = mid;
                else lo = mid;
            }
            set(lo);
        };
        const fitAll = () => {
            const nonJa = !isJa();
            layers().forEach((L) => {
                const bs = [];
                L.querySelectorAll("*").forEach((e) => {
                    if (e.style.getPropertyValue("--fs")) bs.push(e);
                });
                if (nonJa) bs.forEach(applyOverride);
                bs.forEach(fitBox);
            });
        };

        const imgFor = (layer) => {
            const a = layer.closest("a");
            return a ? a.querySelector("img") : null;
        };
        const imgs = () => layers().map(imgFor).filter(Boolean);
        const toWordless = (src) =>
            src.replace(/-ja(\.[a-z0-9]+)(?=($|[?#]))/i, "-wordless$1");
        const toJa = (src) =>
            src.replace(/-wordless(\.[a-z0-9]+)(?=($|[?#]))/i, "-ja$1");
        const swapImages = (toBaked) => {
            imgs().forEach((img) => {
                const cur = img.getAttribute("src") || "";
                const next = toBaked ? toJa(cur) : toWordless(cur);
                if (next !== cur) img.setAttribute("src", next);
            });
        };
        const preloadJa = () => {
            imgs().forEach((img) => {
                const ja = toJa(img.getAttribute("src") || "");
                if (/-ja\./i.test(ja)) new Image().src = ja;
            });
        };

        const st = (window[NS] = window[NS] || {});
        const stopObs = () => {
            if (st.obs) st.obs.forEach((o) => o.disconnect());
            st.obs = null;
        };
        const startObs = () => {
            const obs = [];
            const oLang = new MutationObserver(run);
            oLang.observe(html, {
                attributes: true,
                attributeFilter: ["lang"],
            });
            obs.push(oLang);
            layers().forEach((L) => {
                const oText = new MutationObserver(run);
                oText.observe(L, {
                    childList: true,
                    characterData: true,
                    subtree: true,
                });
                obs.push(oText);
                const a = L.closest("a");
                if (a) {
                    const oImg = new MutationObserver(run);
                    oImg.observe(a, { childList: true });
                    obs.push(oImg);
                }
            });
            st.obs = obs;
        };

        const apply = () => {
            stopObs();
            restoreFs();
            fitAll();
            startObs();
        };
        const run = () => {
            cancelAnimationFrame(st.raf);
            st.raf = requestAnimationFrame(apply);
        };

        stopObs();
        if (st.onResize) window.removeEventListener("resize", st.onResize);
        st.onResize = run;
        window.addEventListener("resize", run);
        window.addEventListener("load", () => {
            run();
            const idle =
                window.requestIdleCallback || ((f) => setTimeout(f, 1200));
            idle(preloadJa);
        });
        if (document.fonts && document.fonts.ready)
            document.fonts.ready.then(run);
        setTimeout(run, 500);
        run();

        window.addEventListener("beforeprint", () => swapImages(true));
        window.addEventListener("afterprint", () => swapImages(false));
        const mq = window.matchMedia && window.matchMedia("print");
        if (mq && mq.addEventListener)
            mq.addEventListener("change", (e) => swapImages(e.matches));
    })();
</script>
