    viewBox="0 0 32 32"
    aria-hidden="true"
    focusable="false"
>
    <circle cx="15" cy="16" r="5" fill="none" stroke="currentColor" stroke-width="2.2" />
    <path
        d="M15 6 A10 10 0 1 0 25 16 L25 21"
        fill="none"
        stroke="currentColor"
        stroke-width="2.2"
        stroke-linecap="round"
    />
</svg>