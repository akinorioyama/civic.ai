---
import type { PageRecord } from "../lib/pages";
import { lang2, normalizeAltUrl, site } from "../lib/site";

interface Props {
    page: PageRecord;
    ogType: "website" | "article";
    ogDesc: string;
    ogImg: string;
    pageTitle: string;
}

const { page, ogType, ogDesc, ogImg, pageTitle } = Astro.props;
const zh = lang2(page.data.lang) === "zh";
const brand = zh ? site.title_zh || site.title : site.title;
const fullTitle = pageTitle.includes(brand) ? pageTitle : `${pageTitle} — ${brand}`;
const alt = normalizeAltUrl(page.data.alt_lang_url);
const canonical = `${site.url}${page.url}`;
---
<title>{fullTitle}</title>
<meta name="description" content={ogDesc} />
<meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
<link rel="canonical" href={canonical} />
{alt && <link rel="alternate" hreflang={zh ? "zh-Hant" : "en"} href={canonical} />}
{alt && <link rel="alternate" hreflang={zh ? "en" : "zh-Hant"} href={`${site.url}${alt}`} />}
{alt && <link rel="alternate" hreflang="x-default" href={zh ? `${site.url}${alt}` : canonical} />}
{site.google_site_verification && <meta name="google-site-verification" content={site.google_site_verification} />}
<meta property="og:title" content={pageTitle} />
<meta property="og:description" content={ogDesc} />
<meta property="og:image" content={ogImg} />
<meta property="og:url" content={canonical} />
<meta property="og:type" content={ogType} />
<meta property="og:site_name" content={brand} />
<meta property="og:locale" content={zh ? "zh_TW" : "en_GB"} />
{alt && <meta property="og:locale:alternate" content={zh ? "en_GB" : "zh_TW"} />}
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={pageTitle} />
<meta name="twitter:description" content={ogDesc} />
<meta name="twitter:image" content={ogImg} />
